<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Dark">
            <SolidColorBrush x:Key="AppPageBackgroundBrush" Color="#FF0C0C0C" />
            <SolidColorBrush x:Key="AppTitleBarBrush" Color="#FF101010" />
            <SolidColorBrush x:Key="AppHeroBrush" Color="#FF111111" />
            <SolidColorBrush x:Key="AppSurfaceBrush" Color="#FF141414" />
            <SolidColorBrush x:Key="AppSurfaceRaisedBrush" Color="#FF1A1A1A" />
            <SolidColorBrush x:Key="AppStrokeBrush" Color="#FF272727" />
            <SolidColorBrush x:Key="AppTextBrush" Color="#FFF2F2F2" />
            <SolidColorBrush x:Key="AppSubtleTextBrush" Color="#FFB4B4B4" />
            <SolidColorBrush x:Key="AppMutedTextBrush" Color="#FF787878" />
            <SolidColorBrush x:Key="AppAccentBrush" Color="#FFF2F2F2" />
            <SolidColorBrush x:Key="AppAccentStrongBrush" Color="#FFDADADA" />
            <SolidColorBrush x:Key="AppAccentSoftBrush" Color="#FF1D1D1D" />
            <SolidColorBrush x:Key="AppAccentGlowBrush" Color="#00000000" />
            <SolidColorBrush x:Key="AppOnAccentBrush" Color="#FF080808" />
            <SolidColorBrush x:Key="AppDangerBrush" Color="#FFE05A5A" />
            <SolidColorBrush x:Key="AppDangerSoftBrush" Color="#332A1515" />
            <SolidColorBrush x:Key="AppWarningBrush" Color="#FFE0C26A" />
            <SolidColorBrush x:Key="AppWarningSoftBrush" Color="#332A2415" />
            <SolidColorBrush x:Key="AppSuccessBrush" Color="#FF8ECEA5" />
            <SolidColorBrush x:Key="AppSuccessSoftBrush" Color="#33202A22" />
            <SolidColorBrush x:Key="AppOverlayBrush" Color="#EE0D0D0D" />
            <SolidColorBrush x:Key="AppFloatingToolbarBrush" Color="#F0101010" />
        </ResourceDictionary>
        <ResourceDictionary x:Key="Light">
            <SolidColorBrush x:Key="AppPageBackgroundBrush" Color="#FFF6F6F6" />
            <SolidColorBrush x:Key="AppTitleBarBrush" Color="#FFFFFFFF" />
            <SolidColorBrush x:Key="AppHeroBrush" Color="#FFFFFFFF" />
            <SolidColorBrush x:Key="AppSurfaceBrush" Color="#FFFFFFFF" />
            <SolidColorBrush x:Key="AppSurfaceRaisedBrush" Color="#FFF4F4F4" />
            <SolidColorBrush x:Key="AppStrokeBrush" Color="#FFDADADA" />
            <SolidColorBrush x:Key="AppTextBrush" Color="#FF111111" />
            <SolidColorBrush x:Key="AppSubtleTextBrush" Color="#FF4D4D4D" />
            <SolidColorBrush x:Key="AppMutedTextBrush" Color="#FF747474" />
            <SolidColorBrush x:Key="AppAccentBrush" Color="#FF111111" />
            <SolidColorBrush x:Key="AppAccentStrongBrush" Color="#FF000000" />
            <SolidColorBrush x:Key="AppAccentSoftBrush" Color="#FFF1F1F1" />
            <SolidColorBrush x:Key="AppAccentGlowBrush" Color="#00000000" />
            <SolidColorBrush x:Key="AppOnAccentBrush" Color="#FFFFFFFF" />
            <SolidColorBrush x:Key="AppDangerBrush" Color="#FFC34141" />
            <SolidColorBrush x:Key="AppDangerSoftBrush" Color="#1AC34141" />
            <SolidColorBrush x:Key="AppWarningBrush" Color="#FF886200" />
            <SolidColorBrush x:Key="AppWarningSoftBrush" Color="#1A886200" />
            <SolidColorBrush x:Key="AppSuccessBrush" Color="#FF2A8050" />
            <SolidColorBrush x:Key="AppSuccessSoftBrush" Color="#1A2A8050" />
            <SolidColorBrush x:Key="AppOverlayBrush" Color="#F2FFFFFF" />
            <SolidColorBrush x:Key="AppFloatingToolbarBrush" Color="#FAFFFFFF" />
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

    <Style x:Key="HeroSurfaceStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource AppHeroBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource AppStrokeBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="18" />
    </Style>

    <Style x:Key="SectionSurfaceStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource AppSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource AppStrokeBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="16" />
    </Style>

    <Style x:Key="InsetSurfaceStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource AppSurfaceRaisedBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource AppStrokeBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="12" />
    </Style>

    <Style x:Key="QuietBadgeStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource AppAccentSoftBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource AppStrokeBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="8,4" />
    </Style>

    <Style x:Key="PrimaryActionButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{ThemeResource AppAccentBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource AppAccentStrongBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{ThemeResource AppOnAccentBrush}" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="14,12" />
        <Setter Property="MinHeight" Value="48" />
    </Style>

    <Style x:Key="SecondaryActionButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{ThemeResource AppSurfaceRaisedBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource AppStrokeBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{ThemeResource AppTextBrush}" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="MinHeight" Value="36" />
    </Style>

    <Style x:Key="ToolbarButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="32" />
        <Setter Property="Height" Value="32" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Background" Value="{ThemeResource AppSurfaceRaisedBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource AppStrokeBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{ThemeResource AppTextBrush}" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <Style x:Key="SectionEyebrowTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI Variable" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="CharacterSpacing" Value="60" />
        <Setter Property="Foreground" Value="{ThemeResource AppMutedTextBrush}" />
    </Style>

    <Style x:Key="PageTitleTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI Variable" />
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{ThemeResource AppTextBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="SectionTitleTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI Variable" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{ThemeResource AppTextBrush}" />
    </Style>

    <Style x:Key="SectionBodyTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI Variable" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{ThemeResource AppSubtleTextBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="CaptionLabelTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI Variable" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{ThemeResource AppMutedTextBrush}" />
    </Style>
</ResourceDictionary>
