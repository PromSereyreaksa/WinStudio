<Window
    x:Class="WinStudio.App.Controls.FloatingToolbar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid Background="Transparent">
        <Border
            Background="#CC1A1A1A"
            BorderBrush="#FF2A2A2A"
            BorderThickness="1"
            CornerRadius="9999"
            Padding="10,8">
            <Grid ColumnSpacing="10" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button
                    x:Name="CancelButton"
                    Grid.Column="0"
                    Width="28"
                    Height="28"
                    CornerRadius="14"
                    Background="#FF1F1F1F"
                    Foreground="#FF888888"
                    BorderBrush="#FF2A2A2A"
                    BorderThickness="1"
                    Click="CancelButton_Click"
                    ToolTipService.ToolTip="Cancel recording">
                    <TextBlock Text="&#x2715;" FontSize="12" />
                </Button>

                <Rectangle
                    Grid.Column="1"
                    Width="1"
                    Height="20"
                    Fill="#FF2A2A2A" />

                <StackPanel
                    Grid.Column="2"
                    Orientation="Horizontal"
                    Spacing="8"
                    VerticalAlignment="Center">
                    <Ellipse
                        x:Name="RecordingDot"
                        Width="8"
                        Height="8"
                        Fill="#FFE84040" />
                    <TextBlock
                        x:Name="ElapsedTextBlock"
                        Text="00:00:00"
                        FontFamily="Cascadia Mono"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Foreground="#FFF0F0F0" />
                </StackPanel>

                <Rectangle
                    Grid.Column="3"
                    Width="1"
                    Height="20"
                    Fill="#FF2A2A2A" />

                <Button
                    x:Name="PauseButton"
                    Grid.Column="4"
                    Width="28"
                    Height="28"
                    CornerRadius="14"
                    Background="#FF1F1F1F"
                    Foreground="#FF888888"
                    BorderBrush="#FF2A2A2A"
                    BorderThickness="1"
                    Click="PauseButton_Click"
                    ToolTipService.ToolTip="Pause (Ctrl+Shift+P)">
                    <TextBlock x:Name="PauseGlyphTextBlock" Text="||" FontSize="12" />
                </Button>

                <Button
                    Grid.Column="5"
                    Width="28"
                    Height="28"
                    CornerRadius="14"
                    Background="#FF1F1F1F"
                    Foreground="#FF888888"
                    BorderBrush="#FF2A2A2A"
                    BorderThickness="1"
                    IsEnabled="False"
                    Opacity="0.35"
                    ToolTipService.ToolTip="Microphone (coming soon)">
                    <FontIcon Glyph="&#xE720;" FontSize="12" />
                </Button>

                <Rectangle
                    Grid.Column="6"
                    Width="1"
                    Height="20"
                    Fill="#FF2A2A2A" />

                <Button
                    x:Name="StopButton"
                    Grid.Column="7"
                    Width="32"
                    Height="32"
                    CornerRadius="16"
                    Background="#FFE84040"
                    Foreground="White"
                    BorderBrush="#FFE84040"
                    BorderThickness="1"
                    Padding="0"
                    Click="StopButton_Click"
                    ToolTipService.ToolTip="Stop and save (Ctrl+Shift+R)">
                    <TextBlock Text="&#x25A0;" FontSize="11" />
                </Button>
            </Grid>
        </Border>

        <Border
            x:Name="CountdownOverlay"
            Background="#CC0D0D0D"
            CornerRadius="14"
            Padding="16,8"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Visibility="Collapsed">
            <TextBlock
                x:Name="CountdownTextBlock"
                Text="3"
                FontFamily="Cascadia Mono"
                FontSize="24"
                FontWeight="SemiBold"
                Foreground="#FFF0F0F0" />
        </Border>
    </Grid>
</Window>
