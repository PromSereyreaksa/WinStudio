<Window
    x:Class="WinStudio.App.Controls.FloatingToolbar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid Background="Transparent">
        <Border
            Background="{ThemeResource AppFloatingToolbarBrush}"
            BorderBrush="{ThemeResource AppStrokeBrush}"
            BorderThickness="1"
            CornerRadius="4"
            Padding="8,6">
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Rectangle
                    x:Name="RecordingDot"
                    Grid.Column="0"
                    Width="8"
                    Height="8"
                    Fill="{ThemeResource AppDangerBrush}"
                    VerticalAlignment="Center" />

                <TextBlock
                    x:Name="StateBadgeTextBlock"
                    Grid.Column="1"
                    Text="REC"
                    FontFamily="Cascadia Mono"
                    FontSize="12"
                    FontWeight="SemiBold"
                    Foreground="{ThemeResource AppTextBrush}"
                    VerticalAlignment="Center" />

                <TextBlock
                    x:Name="ElapsedTextBlock"
                    Grid.Column="2"
                    Text="00:00:00"
                    FontFamily="Cascadia Mono"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Foreground="{ThemeResource AppTextBrush}"
                    VerticalAlignment="Center" />

                <Button
                    x:Name="PauseButton"
                    Grid.Column="3"
                    Style="{StaticResource ToolbarButtonStyle}"
                    Click="PauseButton_Click"
                    ToolTipService.ToolTip="Pause (Ctrl+Shift+P)">
                    <TextBlock
                        x:Name="PauseGlyphTextBlock"
                        Text="||"
                        FontFamily="Cascadia Mono"
                        FontSize="12"
                        FontWeight="SemiBold" />
                </Button>

                <Button
                    x:Name="StopButton"
                    Grid.Column="4"
                    Style="{StaticResource ToolbarButtonStyle}"
                    Background="{ThemeResource AppDangerBrush}"
                    BorderBrush="{ThemeResource AppDangerBrush}"
                    Foreground="{ThemeResource AppOnAccentBrush}"
                    Click="StopButton_Click"
                    ToolTipService.ToolTip="Stop and save (Ctrl+Shift+R)">
                    <TextBlock
                        Text="[]"
                        FontFamily="Cascadia Mono"
                        FontSize="10"
                        FontWeight="SemiBold" />
                </Button>

                <Button
                    x:Name="CancelButton"
                    Grid.Column="5"
                    Style="{StaticResource ToolbarButtonStyle}"
                    Click="CancelButton_Click"
                    ToolTipService.ToolTip="Cancel recording">
                    <TextBlock
                        Text="X"
                        FontFamily="Cascadia Mono"
                        FontSize="11"
                        FontWeight="SemiBold" />
                </Button>
            </Grid>
        </Border>

        <Border
            x:Name="CountdownOverlay"
            Background="{ThemeResource AppOverlayBrush}"
            BorderBrush="{ThemeResource AppStrokeBrush}"
            BorderThickness="1"
            CornerRadius="4"
            Padding="14,10"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Visibility="Collapsed">
            <StackPanel Spacing="4">
                <TextBlock
                    Text="Starting"
                    FontFamily="Segoe UI Variable"
                    FontSize="11"
                    Foreground="{ThemeResource AppMutedTextBrush}"
                    HorizontalAlignment="Center" />
                <TextBlock
                    x:Name="CountdownTextBlock"
                    Text="3"
                    FontFamily="Cascadia Mono"
                    FontSize="28"
                    FontWeight="SemiBold"
                    Foreground="{ThemeResource AppTextBrush}"
                    HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
