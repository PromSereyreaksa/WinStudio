<Window
    x:Class="WinStudio.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="WinStudio">
    <Grid Background="{ThemeResource AppPageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="44" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Background="{ThemeResource AppTitleBarBrush}"
            BorderBrush="{ThemeResource AppStrokeBrush}"
            BorderThickness="0,0,0,1">
            <Grid
                x:Name="TitleBarDragRegion"
                Padding="14,0,14,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Text="WinStudio"
                    FontFamily="Segoe UI Variable"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Foreground="{ThemeResource AppTextBrush}"
                    VerticalAlignment="Center" />

                <TextBlock
                    Grid.Column="1"
                    Text="Recorder"
                    FontFamily="Segoe UI Variable"
                    FontSize="11"
                    Foreground="{ThemeResource AppMutedTextBrush}"
                    VerticalAlignment="Center" />
            </Grid>
        </Border>

        <Frame x:Name="RootFrame" Grid.Row="1" />
    </Grid>
</Window>
