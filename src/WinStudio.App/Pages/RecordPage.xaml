<Page
    x:Class="WinStudio.App.Pages.RecordPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:WinStudio.App.Controls"
    mc:Ignorable="d">
    <Page.Resources>
        <!-- Minimal RadioButton style for colour-swatch pickers. Shows only the
             coloured circle; a white ring appears when the button is checked. -->
        <Style x:Key="ColorSwatchStyle" TargetType="RadioButton">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border
                            x:Name="SwatchBorder"
                            Width="34"
                            Height="34"
                            CornerRadius="17"
                            Background="{TemplateBinding Background}"
                            BorderThickness="2.5"
                            BorderBrush="Transparent">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CheckStates">
                                    <VisualState x:Name="Checked">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames
                                                Storyboard.TargetName="SwatchBorder"
                                                Storyboard.TargetProperty="BorderBrush">
                                                <DiscreteObjectKeyFrame KeyTime="0">
                                                    <DiscreteObjectKeyFrame.Value>
                                                        <SolidColorBrush Color="White" />
                                                    </DiscreteObjectKeyFrame.Value>
                                                </DiscreteObjectKeyFrame>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Unchecked" />
                                    <VisualState x:Name="Indeterminate" />
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Background="{ThemeResource AppPageBackgroundBrush}">
            <StackPanel Margin="24" Spacing="16">
                <Border Style="{StaticResource HeroSurfaceStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="RECORD" Style="{StaticResource SectionEyebrowTextStyle}" />
                        <TextBlock Text="Start a recording" Style="{StaticResource PageTitleTextStyle}" />
                        <TextBlock
                            Text="Follow the steps from top to bottom. Choose what to record, adjust tracking if needed, then start."
                            Style="{StaticResource SectionBodyTextStyle}" />
                        <TextBlock
                            x:Name="StatusTextBlock"
                            Style="{StaticResource CaptionLabelTextStyle}"
                            MinHeight="18"
                            Text="Ready." />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionSurfaceStyle}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="1. Choose what to record" Style="{StaticResource SectionTitleTextStyle}" />

                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <ToggleButton
                                x:Name="WindowCaptureToggle"
                                Grid.Column="0"
                                Height="44"
                                Checked="WindowCaptureToggle_Checked"
                                CornerRadius="4"
                                Content="Window" />

                            <ToggleButton
                                x:Name="MonitorCaptureToggle"
                                Grid.Column="1"
                                Height="44"
                                Checked="MonitorCaptureToggle_Checked"
                                CornerRadius="4"
                                Content="Monitor" />
                        </Grid>

                        <Border
                            x:Name="WindowPickerCard"
                            Style="{StaticResource InsetSurfaceStyle}">
                            <StackPanel Spacing="10">
                                <Grid ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Spacing="2">
                                        <TextBlock
                                            Text="Pick the window"
                                            FontFamily="Segoe UI Variable"
                                            FontSize="14"
                                            FontWeight="SemiBold"
                                            Foreground="{ThemeResource AppTextBrush}" />
                                        <TextBlock
                                            Text="Required for window recording."
                                            Style="{StaticResource CaptionLabelTextStyle}" />
                                    </StackPanel>

                                    <Button
                                        x:Name="RefreshWindowsButton"
                                        Grid.Column="1"
                                        Style="{StaticResource SecondaryActionButtonStyle}"
                                        Click="RefreshWindowsButton_Click"
                                        Content="Refresh" />
                                </Grid>

                                <ComboBox
                                    x:Name="WindowPickerComboBox"
                                    PlaceholderText="Select a window"
                                    SelectionChanged="WindowPickerComboBox_SelectionChanged" />

                                <TextBlock
                                    x:Name="WindowSelectionHintTextBlock"
                                    Style="{StaticResource CaptionLabelTextStyle}"
                                    Text="No window selected." />
                            </StackPanel>
                        </Border>

                        <TextBlock
                            x:Name="CaptureSummaryTextBlock"
                            Style="{StaticResource CaptionLabelTextStyle}" />

                        <Border
                            x:Name="RecordingPreviewCard"
                            Style="{StaticResource InsetSurfaceStyle}">
                            <StackPanel Spacing="10">
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock
                                        Text="Recording preview"
                                        FontFamily="Segoe UI Variable"
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        Foreground="{ThemeResource AppTextBrush}" />

                                    <TextBlock
                                        x:Name="PreviewModeTextBlock"
                                        Grid.Column="1"
                                        Style="{StaticResource CaptionLabelTextStyle}" />
                                </Grid>

                                <Border
                                    Height="196"
                                    CornerRadius="12"
                                    BorderThickness="1"
                                    BorderBrush="{ThemeResource AppStrokeBrush}">
                                    <Grid>
                                        <Border
                                            x:Name="PreviewBackdropBorder"
                                            Background="{ThemeResource AppSurfaceRaisedBrush}" />

                                        <Image
                                            x:Name="PreviewBackdropImage"
                                            Stretch="UniformToFill"
                                            Visibility="Collapsed" />

                                        <Border
                                            x:Name="PreviewWindowFrame"
                                            Width="264"
                                            Height="150"
                                            CornerRadius="12"
                                            Background="{ThemeResource AppSurfaceBrush}"
                                            BorderThickness="1"
                                            BorderBrush="{ThemeResource AppStrokeBrush}"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                            <Grid>
                                                <Border
                                                    Height="28"
                                                    Background="{ThemeResource AppOverlayBrush}"
                                                    VerticalAlignment="Top"
                                                    CornerRadius="12,12,0,0">
                                                    <Grid Padding="12,0" ColumnSpacing="10">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>

                                                        <StackPanel
                                                            Orientation="Horizontal"
                                                            Spacing="5"
                                                            VerticalAlignment="Center">
                                                            <Ellipse Width="7" Height="7" Fill="#FFFB7185" />
                                                            <Ellipse Width="7" Height="7" Fill="#FFFBBF24" />
                                                            <Ellipse Width="7" Height="7" Fill="#FF34D399" />
                                                        </StackPanel>

                                                        <TextBlock
                                                            x:Name="PreviewWindowTitleTextBlock"
                                                            Grid.Column="1"
                                                            Style="{StaticResource CaptionLabelTextStyle}"
                                                            VerticalAlignment="Center"
                                                            TextTrimming="CharacterEllipsis" />
                                                    </Grid>
                                                </Border>

                                                <StackPanel Margin="16,48,16,16" Spacing="8">
                                                    <Border
                                                        Height="12"
                                                        Width="148"
                                                        CornerRadius="6"
                                                        Background="{ThemeResource AppSurfaceRaisedBrush}" />
                                                    <Border
                                                        Height="10"
                                                        Width="208"
                                                        CornerRadius="5"
                                                        Background="{ThemeResource AppSurfaceRaisedBrush}" />
                                                    <Border
                                                        Height="10"
                                                        Width="176"
                                                        CornerRadius="5"
                                                        Background="{ThemeResource AppSurfaceRaisedBrush}" />
                                                    <Grid Margin="0,10,0,0" ColumnSpacing="8">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>

                                                        <Border
                                                            Width="72"
                                                            Height="22"
                                                            CornerRadius="11"
                                                            Background="{ThemeResource AppAccentBrush}" />
                                                        <Border
                                                            Grid.Column="1"
                                                            Width="72"
                                                            Height="22"
                                                            CornerRadius="11"
                                                            Background="{ThemeResource AppSurfaceRaisedBrush}" />
                                                    </Grid>
                                                </StackPanel>
                                            </Grid>
                                        </Border>

                                        <Canvas IsHitTestVisible="False">
                                            <Grid
                                                x:Name="PreviewCursorBadge"
                                                Width="34"
                                                Height="34">
                                                <Grid.RenderTransform>
                                                    <CompositeTransform x:Name="PreviewCursorTransform" />
                                                </Grid.RenderTransform>
                                                <Ellipse
                                                    Fill="#F7FFFFFF"
                                                    Stroke="{ThemeResource AppAccentStrongBrush}"
                                                    StrokeThickness="2.5" />
                                                <Ellipse
                                                    Width="8"
                                                    Height="8"
                                                    Fill="{ThemeResource AppAccentBrush}"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center" />
                                            </Grid>
                                        </Canvas>
                                    </Grid>
                                </Border>

                                <TextBlock
                                    x:Name="PreviewCaptionTextBlock"
                                    Style="{StaticResource CaptionLabelTextStyle}"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionSurfaceStyle}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="2. Optional recording settings" Style="{StaticResource SectionTitleTextStyle}" />

                        <Border Style="{StaticResource InsetSurfaceStyle}">
                            <Grid ColumnSpacing="12" MinHeight="44">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="2" VerticalAlignment="Center">
                                    <TextBlock
                                        Text="System audio"
                                        FontFamily="Segoe UI Variable"
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        Foreground="{ThemeResource AppTextBrush}" />
                                    <TextBlock
                                        Text="Capture desktop sound."
                                        Style="{StaticResource CaptionLabelTextStyle}" />
                                </StackPanel>
                                <ToggleSwitch
                                    x:Name="SystemAudioToggle"
                                    Grid.Column="1"
                                    IsOn="True"
                                    Toggled="SystemAudioToggle_Toggled"
                                    VerticalAlignment="Center" />
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource InsetSurfaceStyle}">
                            <StackPanel Spacing="8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        Text="Zoom intensity"
                                        FontFamily="Segoe UI Variable"
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        Foreground="{ThemeResource AppTextBrush}" />
                                    <TextBlock
                                        x:Name="ZoomIntensityPreviewTextBlock"
                                        Grid.Column="1"
                                        FontFamily="Segoe UI Variable"
                                        FontSize="12"
                                        Foreground="{ThemeResource AppSubtleTextBrush}" />
                                </Grid>
                                <Slider
                                    x:Name="ZoomIntensitySlider"
                                    Minimum="0.6"
                                    Maximum="2.2"
                                    StepFrequency="0.1"
                                    ValueChanged="SettingsSlider_ValueChanged" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource InsetSurfaceStyle}">
                            <StackPanel Spacing="8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        Text="Zoom sensitivity"
                                        FontFamily="Segoe UI Variable"
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        Foreground="{ThemeResource AppTextBrush}" />
                                    <TextBlock
                                        x:Name="ZoomSensitivityPreviewTextBlock"
                                        Grid.Column="1"
                                        FontFamily="Segoe UI Variable"
                                        FontSize="12"
                                        Foreground="{ThemeResource AppSubtleTextBrush}" />
                                </Grid>
                                <Slider
                                    x:Name="ZoomSensitivitySlider"
                                    Minimum="0.6"
                                    Maximum="2.0"
                                    StepFrequency="0.1"
                                    ValueChanged="SettingsSlider_ValueChanged" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource InsetSurfaceStyle}">
                            <StackPanel Spacing="8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        Text="Follow speed"
                                        FontFamily="Segoe UI Variable"
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        Foreground="{ThemeResource AppTextBrush}" />
                                    <TextBlock
                                        x:Name="FollowSpeedPreviewTextBlock"
                                        Grid.Column="1"
                                        FontFamily="Segoe UI Variable"
                                        FontSize="12"
                                        Foreground="{ThemeResource AppSubtleTextBrush}" />
                                </Grid>
                                <Slider
                                    x:Name="FollowSpeedSlider"
                                    Minimum="0.6"
                                    Maximum="2.0"
                                    StepFrequency="0.1"
                                    ValueChanged="SettingsSlider_ValueChanged" />
                            </StackPanel>
                        </Border>

                        <TextBlock
                            x:Name="AudioSummaryTextBlock"
                            Style="{StaticResource CaptionLabelTextStyle}" />
                        <TextBlock
                            x:Name="AutoZoomSummaryTextBlock"
                            Style="{StaticResource CaptionLabelTextStyle}" />

                        <!-- Background backdrop ──────────────────────────── -->
                        <Border Style="{StaticResource InsetSurfaceStyle}">
                            <StackPanel Spacing="12">
                                <Grid ColumnSpacing="12" MinHeight="44">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Spacing="2" VerticalAlignment="Center">
                                        <TextBlock
                                            Text="Background"
                                            FontFamily="Segoe UI Variable"
                                            FontSize="14"
                                            FontWeight="SemiBold"
                                            Foreground="{ThemeResource AppTextBrush}" />
                                        <TextBlock
                                            Text="Place the window on a coloured backdrop."
                                            Style="{StaticResource CaptionLabelTextStyle}" />
                                    </StackPanel>
                                    <ToggleSwitch
                                        x:Name="BackgroundToggle"
                                        Grid.Column="1"
                                        IsOn="True"
                                        VerticalAlignment="Center"
                                        Toggled="BackgroundToggle_Toggled" />
                                </Grid>

                                <!-- Options (hidden when toggle is off) -->
                                <StackPanel
                                    x:Name="BackgroundOptionsPanel"
                                    Visibility="Visible"
                                    Spacing="10">
                                    <TextBlock
                                        Text="Colour"
                                        Style="{StaticResource CaptionLabelTextStyle}" />
                                    <ScrollViewer
                                        HorizontalScrollBarVisibility="Auto"
                                        VerticalScrollBarVisibility="Disabled">
                                        <StackPanel
                                            x:Name="BackgroundSwatchContainer"
                                            Orientation="Horizontal"
                                            Spacing="8" />
                                    </ScrollViewer>
                                    <TextBlock
                                        Text="Wallpapers"
                                        Style="{StaticResource CaptionLabelTextStyle}" />
                                    <Grid ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <ToggleButton
                                            x:Name="WallpaperPresetOneButton"
                                            Grid.Column="0"
                                            Checked="WallpaperPresetButton_Checked"
                                            Unchecked="WallpaperPresetButton_Unchecked">
                                            <StackPanel Spacing="6">
                                                <Border
                                                    Height="88"
                                                    CornerRadius="8"
                                                    BorderThickness="1"
                                                    BorderBrush="{ThemeResource AppStrokeBrush}">
                                                    <Image
                                                        x:Name="WallpaperPresetOneImage"
                                                        Stretch="UniformToFill" />
                                                </Border>
                                                <TextBlock
                                                    Text="Wallpaper 1"
                                                    HorizontalAlignment="Center"
                                                    Style="{StaticResource CaptionLabelTextStyle}" />
                                            </StackPanel>
                                        </ToggleButton>

                                        <ToggleButton
                                            x:Name="WallpaperPresetTwoButton"
                                            Grid.Column="1"
                                            Checked="WallpaperPresetButton_Checked"
                                            Unchecked="WallpaperPresetButton_Unchecked">
                                            <StackPanel Spacing="6">
                                                <Border
                                                    Height="88"
                                                    CornerRadius="8"
                                                    BorderThickness="1"
                                                    BorderBrush="{ThemeResource AppStrokeBrush}">
                                                    <Image
                                                        x:Name="WallpaperPresetTwoImage"
                                                        Stretch="UniformToFill" />
                                                </Border>
                                                <TextBlock
                                                    Text="Wallpaper 2"
                                                    HorizontalAlignment="Center"
                                                    Style="{StaticResource CaptionLabelTextStyle}" />
                                            </StackPanel>
                                        </ToggleButton>
                                    </Grid>
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            x:Name="BackgroundImagePathTextBlock"
                                            Style="{StaticResource CaptionLabelTextStyle}"
                                            Text="Or pick a custom image file."
                                            VerticalAlignment="Center"
                                            TextTrimming="CharacterEllipsis" />
                                        <Button
                                            x:Name="BackgroundBrowseButton"
                                            Grid.Column="1"
                                            Style="{StaticResource SecondaryActionButtonStyle}"
                                            Content="Browse"
                                            Click="BackgroundBrowseButton_Click" />
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionSurfaceStyle}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="3. Start" Style="{StaticResource SectionTitleTextStyle}" />
                        <TextBlock
                            x:Name="ReadinessTextBlock"
                            Style="{StaticResource SectionBodyTextStyle}" />
                        <Button
                            x:Name="StartRecordingButton"
                            Style="{StaticResource PrimaryActionButtonStyle}"
                            Click="StartRecordingButton_Click"
                            Content="Start recording" />
                        <TextBlock
                            x:Name="StartRecordingSecondaryTextBlock"
                            Style="{StaticResource CaptionLabelTextStyle}" />

                        <Border Style="{StaticResource InsetSurfaceStyle}">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Shortcuts" Style="{StaticResource SectionTitleTextStyle}" />
                                <controls:HotkeyBadge Label="Start / Stop" HotkeyText="Ctrl + Shift + R" />
                                <controls:HotkeyBadge Label="Pause" HotkeyText="Ctrl + Shift + P" />
                                <controls:HotkeyBadge Label="Cancel" HotkeyText="Esc" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
