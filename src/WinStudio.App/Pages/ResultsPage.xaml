<Page
    x:Class="WinStudio.App.Pages.ResultsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Background="{ThemeResource AppPageBackgroundBrush}">
            <StackPanel Margin="32,28,32,36" Spacing="20">
                <Border Style="{StaticResource HeroSurfaceStyle}">
                    <StackPanel Spacing="10">
                        <TextBlock
                            Text="OUTPUT"
                            Style="{StaticResource SectionEyebrowTextStyle}" />
                        <TextBlock
                            Text="Recording ready"
                            Style="{StaticResource PageTitleTextStyle}" />
                        <TextBlock
                            x:Name="SummaryTextBlock"
                            Style="{StaticResource SectionBodyTextStyle}" />
                        <Border
                            x:Name="ProcessingWarningBorder"
                            Background="{ThemeResource AppWarningSoftBrush}"
                            BorderBrush="{ThemeResource AppWarningBrush}"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="12"
                            Visibility="Collapsed">
                            <TextBlock
                                x:Name="ProcessingWarningTextBlock"
                                FontFamily="Segoe UI Variable"
                                FontSize="12"
                                Foreground="{ThemeResource AppWarningBrush}"
                                TextWrapping="Wrap" />
                        </Border>
                    </StackPanel>
                </Border>

                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border
                        Grid.Column="0"
                        Style="{StaticResource SectionSurfaceStyle}">
                        <StackPanel Spacing="14">
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ToggleButton
                                    x:Name="EditedPreviewToggle"
                                    Grid.Column="0"
                                    Height="40"
                                    Checked="EditedPreviewToggle_Checked"
                                    CornerRadius="12"
                                    Content="Edited preview" />
                                <ToggleButton
                                    x:Name="RawPreviewToggle"
                                    Grid.Column="1"
                                    Height="40"
                                    Checked="RawPreviewToggle_Checked"
                                    CornerRadius="12"
                                    Content="Raw preview" />
                            </Grid>

                            <Grid>
                                <MediaPlayerElement
                                    x:Name="PreviewPlayerElement"
                                    AreTransportControlsEnabled="True"
                                    AutoPlay="False"
                                    MinHeight="390"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch" />

                                <Border
                                    x:Name="PreviewUnavailableOverlay"
                                    Background="{ThemeResource AppOverlayBrush}"
                                    CornerRadius="16"
                                    Visibility="Collapsed">
                                    <StackPanel
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Spacing="8">
                                        <TextBlock
                                            Text="Preview unavailable"
                                            FontFamily="Segoe UI Variable"
                                            FontSize="18"
                                            FontWeight="SemiBold"
                                            Foreground="{ThemeResource AppTextBrush}"
                                            HorizontalAlignment="Center" />
                                        <TextBlock
                                            x:Name="PreviewUnavailableTextBlock"
                                            Style="{StaticResource CaptionLabelTextStyle}"
                                            TextAlignment="Center"
                                            TextWrapping="Wrap"
                                            MaxWidth="320" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Column="1" Spacing="16">
                        <Border Style="{StaticResource SectionSurfaceStyle}">
                            <StackPanel Spacing="10">
                                <TextBlock
                                    Text="Actions"
                                    Style="{StaticResource SectionTitleTextStyle}" />
                                <Button
                                    x:Name="OpenEditedButton"
                                    Style="{StaticResource PrimaryActionButtonStyle}"
                                    Click="OpenEditedButton_Click"
                                    Content="Open edited video" />
                                <Button
                                    x:Name="OpenRawButton"
                                    Style="{StaticResource SecondaryActionButtonStyle}"
                                    Click="OpenRawButton_Click"
                                    Content="Open raw video" />
                                <Button
                                    Style="{StaticResource SecondaryActionButtonStyle}"
                                    Click="OpenFolderButton_Click"
                                    Content="Open output folder" />
                                <Button
                                    Style="{StaticResource SecondaryActionButtonStyle}"
                                    Click="NewRecordingButton_Click"
                                    Content="New recording" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SectionSurfaceStyle}">
                            <StackPanel Spacing="12">
                                <TextBlock
                                    Text="Files"
                                    Style="{StaticResource SectionTitleTextStyle}" />
                                <StackPanel Spacing="4">
                                    <TextBlock
                                        Text="Edited"
                                        FontFamily="Segoe UI Variable"
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Foreground="{ThemeResource AppAccentBrush}" />
                                    <TextBlock
                                        x:Name="EditedPathTextBlock"
                                        FontFamily="Cascadia Mono"
                                        FontSize="11"
                                        Foreground="{ThemeResource AppSubtleTextBrush}"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <TextBlock
                                        Text="Raw"
                                        FontFamily="Segoe UI Variable"
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Foreground="{ThemeResource AppAccentBrush}" />
                                    <TextBlock
                                        x:Name="RawPathTextBlock"
                                        FontFamily="Cascadia Mono"
                                        FontSize="11"
                                        Foreground="{ThemeResource AppSubtleTextBrush}"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <TextBlock
                                        Text="Cursor and zoom data"
                                        FontFamily="Segoe UI Variable"
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Foreground="{ThemeResource AppAccentBrush}" />
                                    <TextBlock
                                        x:Name="DataPathTextBlock"
                                        FontFamily="Cascadia Mono"
                                        FontSize="11"
                                        Foreground="{ThemeResource AppSubtleTextBrush}"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
